/// EXERCÍCIO 10
////////////////////////////////////////////////////

void gerarEventos(StreamController controller) {
  final random = Random();
  final eventos = ["click", "scroll", "input"];

  Timer.periodic(Duration(milliseconds: 400), (timer) {
    String evento = eventos[random.nextInt(eventos.length)];

    print("Evento gerado: $evento");

    controller.sink.add(evento);

    if (timer.tick == 10) {
      timer.cancel();
      controller.close();
    }
  });
}

