  print("Pedidos: $pedidos");

  print("\n===== EXERCÍCIO 4 =====");

  final inicio = DateTime.now();

  final resultados = await Future.wait([
    buscarCategorias(),
    buscarProdutos(),
    buscarPromocoes(),
  ]);

  final fim = DateTime.now();

  print("Categorias: ${resultados[0]}");
  print("Produtos: ${resultados[1]}");
  print("Promoções: ${resultados[2]}");
  print("Tempo total: ${fim.difference(inicio).inSeconds} segundos");

  print("\n===== EXERCÍCIO 5 =====")

  try {
    final resultado =
        await buscarDadosLentos().timeout(Duration(seconds: 3));
    print(resultado);
  } on TimeoutException {
    print("Operação demorou muito!");
  }

  print("\n===== EXERCÍCIO 6 =====");

  await for (var numero in contadorStream()) {
    print(numero);
  }

  print("\n===== EXERCÍCIO 7 =====");

  final controller = StreamController<String>();

  controller.stream.listen((mensagem) {
    print("Chat: $mensagem");
  });

  for (int i = 1; i <= 5; i++) {
    await Future.delayed(Duration(seconds: 1));
    controller.sink.add("Mensagem $i");
  }

  await controller.close();

  print("\n===== EXERCÍCIO 8 =====");

  numerosStream()
      .where((n) => n % 2 == 0)
      .map((n) => n * 2)
      .take(5)
      .listen((n) => print(n));

  await Future.delayed(Duration(seconds: 1));

  ////////////////////////////////////////////////////
  /// EXERCÍCIO 9
  ////////////////////////////////////////////////////

  print("\n===== EXERCÍCIO 9 =====");

  final broadcastController = StreamController<int>.broadcast();

  broadcastController.stream.listen((n) {
    print("Listener 1: $n");
  });

  broadcastController.stream.listen((n) {
    print("Listener 2 quadrado: ${n * n}");
  });

  int soma = 0;
  broadcastController.stream.listen((n) {
    soma += n;
    print("Listener 3 soma: $soma");
  });

  for (int i = 1; i <= 10; i++) {
    await Future.delayed(Duration(milliseconds: 500));
    broadcastController.sink.add(i);
  }

  await broadcastController.close();

  ////////////////////////////////////////////////////
  /// EXERCÍCIO 10
  ////////////////////////////////////////////////////

  print("\n===== EXERCÍCIO 10 =====");

  final eventController = StreamController<String>();
  Timer? debounce;

  eventController.stream.listen((evento) {
    debounce?.cancel();

    debounce = Timer(Duration(seconds: 1), () {
      print("Processando evento final: $evento");
    });
  });

  gerarEventos(eventController);

  await Future.delayed(Duration(seconds: 6));

  ////////////////////////////////////////////////////
  /// EXERCÍCIO 11
  ////////////////////////////////////////////////////

  print("\n===== EXERCÍCIO 11 =====");

  print(await buscarConfiguracao("tema"));
  print(await buscarConfiguracao("idioma"));
  print(await buscarConfiguracao("inexistente"));

  ////////////////////////////////////////////////////
  /// EXERCÍCIO 12
  ////////////////////////////////////////////////////

  print("\n===== EXERCÍCIO 12 =====");

  try {
    final tokenDashboard = await autenticarUsuario();

    final dados = await Future.wait([
      buscarPerfilDashboard(tokenDashboard),
      buscarNotificacoesDashboard(tokenDashboard),
      buscarEstatisticasDashboard(tokenDashboard)
    ]);

    print("Perfil: ${dados[0]}");
    print("Notificações: ${dados[1]}");
    print("Estatísticas: ${dados[2]}");

    print("\nAtualizações em tempo real:");

    await for (var evento in streamAtualizacoes()) {
      print("Update: $evento");
    }

  } catch (e) {
    print("Erro no dashboard: $e");
  }
}

